    {
      "id": "IY938oXm2Kogu0GWuZDIJ",
      "type": "text",
      "x": 1918.2198181152344,
      "y": 245.30555661519372,
      "width": 891.679443359375,
      "height": 375,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "au",
      "roundness": null,
      "seed": 1760874163,
      "version": 615,
      "versionNonce": 815514675,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781568936715,
      "link": null,
      "locked": false,
      "text": "~ Suppose the university reverts the following:-\n    - current placement ratio is 20%\n    - Desired placement ratio is 30%\n    - placement ratio is decrease around last year(2024)\n    - the average CGPA of the student is 7.5\n    -the average CGPA required for placement is 8\n    -academic factor that affect the placement most id CGPA\n    - AI is prefer by the placement officer\n    - TCS, Infosys ,Wipro ,daffodil software\n    -Infosys visit frenquently\n    - preparation is complete around 3 year\n    - 2 hour per day spend time for peparation\n    -  the student weak point is communication skill, coding skill, how to explain your answer\n    - average interview  student are given is 3\n    - student is study in 2nd year",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "~ Suppose the university reverts the following:-\n    - current placement ratio is 20%\n    - Desired placement ratio is 30%\n    - placement ratio is decrease around last year(2024)\n    - the average CGPA of the student is 7.5\n    -the average CGPA required for placement is 8\n    -academic factor that affect the placement most id CGPA\n    - AI is prefer by the placement officer\n    - TCS, Infosys ,Wipro ,daffodil software\n    -Infosys visit frenquently\n    - preparation is complete around 3 year\n    - 2 hour per day spend time for peparation\n    -  the student weak point is communication skill, coding skill, how to explain your answer\n    - average interview  student are given is 3\n    - student is study in 2nd year",
      "autoResize": true,
      "lineHeight": 1.25
    },
