      "link": null,
      "locked": false,
      "text": "\n\nStep 2 :-     Define the problem precisely\n    \n    - poor problem statement\n            - \" Prepare students for placement\"\n\n    - Better apporach\n\n        - \"  help 2nd year student star preparation for placement and it is completed around 3rd year\n            so that they can improve their chances of getting placed in their desired company\"",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\n\nStep 2 :-     Define the problem precisely\n    \n    - poor problem statement\n            - \" Prepare students for placement\"\n\n    - Better apporach\n\n        - \"  help 2nd year student star preparation for placement and it is completed around 3rd year\n            so that they can improve their chances of getting placed in their desired company\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
