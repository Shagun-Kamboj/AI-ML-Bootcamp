    {
      "id": "Dxebfq54ar6qAySwghsEz",
      "type": "text",
      "x": 4269.587560017905,
      "y": 537.5292458912684,
      "width": 663.4195556640625,
      "height": 400,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
