    {
      "id": "pOfrKsDKpituAuibcd0kV",
      "type": "text",
      "x": 1148.4038692540153,
      "y": 180.721086488631,
      "width": 538.9996337890625,
      "height": 725,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ao",
      "roundness": null,
      "seed": 1841274738,
      "version": 1121,
      "versionNonce": 952435581,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781568849730,
      "link": null,
      "locked": false,
      "text": "Step 1    Understand the Business problem\n      \n   Initial Statement :- student is reject in interview\n \n-> Need to uncover the actual problem\n        \n   The AI team will ask themselves multiple questions:-\n        \n   Questions for Stakeholders:-\n    \n~ To academic department :-\n    - What is the current placement ratio?\n    - since when has it decreased?\n    - what is the average CGPA of the student?\n    - what is the minimum CGPA required for placement?\n    - which academic factor affect the placement most?\n\n~ To Placement cell:-\n    - which skill is prefer by the placement officer?\n    - which companies visit in the campus?\n    - which company visit many times?\n    - how much time is available for placement?\n\n~ To student:-\n    - How many time is spend for preparation?\n    -what is the common weak point of the student?\n    -how many average interview  student are given?\n    - which year students are studied?\n   ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 1    Understand the Business problem\n      \n   Initial Statement :- student is reject in interview\n \n-> Need to uncover the actual problem\n        \n   The AI team will ask themselves multiple questions:-\n        \n   Questions for Stakeholders:-\n    \n~ To academic department :-\n    - What is the current placement ratio?\n    - since when has it decreased?\n    - what is the average CGPA of the student?\n    - what is the minimum CGPA required for placement?\n    - which academic factor affect the placement most?\n\n~ To Placement cell:-\n    - which skill is prefer by the placement officer?\n    - which companies visit in the campus?\n    - which company visit many times?\n    - how much time is available for placement?\n\n~ To student:-\n    - How many time is spend for preparation?\n    -what is the common weak point of the student?\n    -how many average interview  student are given?\n    - which year students are studied?\n   ",
      "autoResize": true,
      "lineHeight": 1.25
    },
