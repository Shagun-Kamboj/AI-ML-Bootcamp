    {
      "id": "lg7CvhNm6gr-QzkkvEWwk",
      "type": "text",
      "x": 3958.486805332156,
      "y": 344.54721395394876,
      "width": 658.1197509765625,
      "height": 325,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b22",
      "roundness": null,
      "seed": 1389905006,
      "version": 361,
      "versionNonce": 649189234,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782090701286,
      "link": null,
      "locked": false,
      "text": " Step 5 :- Define the AI tasks\n\n    - Machine learning formulation:-\n        - classification problem\n            - output -> take hostel room= yes/ take hostel room= no\n                - binary classification problem\n    \n    - Risk scoring\n        -How likely take hostel room? 0-100%\n\n    - ranking problem :-\n        - top 200 student whose take hostel room\n           give 10% discount",
      "fontSize": 20,
      "fontFamily": 5,
