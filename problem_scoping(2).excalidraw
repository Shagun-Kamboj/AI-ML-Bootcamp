      "versionNonce": 1572050094,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782090025538,
      "link": null,
      "locked": false,
      "text": "Step 4:- Identifying stakeholders:-\n\nstakeholders mapping:-\n\n- administration cell :- prevent shortage of rooms\n- student :- take facility\n- parents :- student success\n- campus :- gain profit\n- faculty :- student reach the class on time",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Step 4:- Identifying stakeholders:-\n\nstakeholders mapping:-\n\n- administration cell :- prevent shortage of rooms\n- student :- take facility\n- parents :- student success\n- campus :- gain profit\n- faculty :- student reach the class on time",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "erUs8fX0F3eT9J6SNYy0d",
      "type": "text",
      "x": 3969.194910939777,
      "y": 342.4055928324246,
